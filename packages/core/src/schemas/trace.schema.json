{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loom.dev/schemas/trace-v1.schema.json",
  "title": "Loom Trace v1",
  "type": "object",
  "required": [
    "version",
    "mode",
    "status",
    "initialFragments",
    "finalFragments",
    "executions",
    "diagnostics"
  ],
  "properties": {
    "version": { "const": "1" },
    "mode": { "enum": ["on", "off"] },
    "status": { "enum": ["ok", "error"] },
    "error": { "$ref": "#/$defs/serializedError" },
    "initialFragments": { "type": "array", "items": { "$ref": "#/$defs/fragment" } },
    "finalFragments": { "type": "array", "items": { "$ref": "#/$defs/fragment" } },
    "passConfigs": { "type": "array", "items": { "$ref": "#/$defs/passConfig" } },
    "executions": { "type": "array", "items": { "$ref": "#/$defs/execution" } },
    "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" } }
  },
  "additionalProperties": false,
  "$defs": {
    "json": true,
    "serializedError": {
      "type": "object",
      "required": ["name", "message"],
      "properties": {
        "name": { "type": "string" },
        "message": { "type": "string" },
        "stack": { "type": "string" }
      },
      "additionalProperties": false
    },
    "fragment": {
      "type": "object",
      "required": ["id", "content", "meta"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "meta": { "$ref": "#/$defs/json" }
      },
      "additionalProperties": false
    },
    "passConfig": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "params": { "$ref": "#/$defs/json" }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["severity", "code", "message", "pass"],
      "properties": {
        "severity": { "enum": ["error", "warning", "info", "hint"] },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "pass": { "type": "string", "minLength": 1 },
        "fragmentId": { "type": "string" },
        "at": { "type": "number" },
        "meta": { "type": "object", "additionalProperties": { "$ref": "#/$defs/json" } },
        "relatedFragmentIds": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "mutation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "fragmentId", "index", "fragment"],
          "properties": {
            "op": { "const": "add" },
            "fragmentId": { "type": "string", "minLength": 1 },
            "index": { "type": "integer", "minimum": 0 },
            "fragment": { "$ref": "#/$defs/fragment" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "fragmentId", "index", "fragment"],
          "properties": {
            "op": { "const": "remove" },
            "fragmentId": { "type": "string", "minLength": 1 },
            "index": { "type": "integer", "minimum": 0 },
            "fragment": { "$ref": "#/$defs/fragment" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "fragmentId", "index", "before", "after"],
          "properties": {
            "op": { "const": "update" },
            "fragmentId": { "type": "string", "minLength": 1 },
            "index": { "type": "integer", "minimum": 0 },
            "before": { "$ref": "#/$defs/fragment" },
            "after": { "$ref": "#/$defs/fragment" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "fragmentId", "fromIndex", "toIndex"],
          "properties": {
            "op": { "const": "move" },
            "fragmentId": { "type": "string", "minLength": 1 },
            "fromIndex": { "type": "integer", "minimum": 0 },
            "toIndex": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      ]
    },
    "snapshot": {
      "type": "object",
      "properties": {
        "before": { "type": "array", "items": { "$ref": "#/$defs/fragment" } },
        "after": { "type": "array", "items": { "$ref": "#/$defs/fragment" } }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": ["passName", "passIndex", "durationMs", "diagnostics", "mutations"],
      "properties": {
        "passName": { "type": "string", "minLength": 1 },
        "passIndex": { "type": "integer", "minimum": 0 },
        "durationMs": { "type": "number", "minimum": 0 },
        "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" } },
        "mutations": { "type": "array", "items": { "$ref": "#/$defs/mutation" } },
        "snapshot": { "$ref": "#/$defs/snapshot" }
      },
      "additionalProperties": false
    }
  }
}
